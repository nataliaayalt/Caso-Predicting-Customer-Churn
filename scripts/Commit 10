# 10 - Análisis de errores del modelo

library(ggplot2)

# Error = real - predicción
data_clean$error <- data_clean$Churn - data_clean$pred

# Gráfico de errores
ggplot(data_clean, aes(x = pred, y = error)) +
  geom_point(alpha = 0.5) +
  geom_hline(yintercept = 0, color = "red") +
  labs(title = "Gráfico de errores del modelo",
       x = "Probabilidad predicha",
       y = "Error")
